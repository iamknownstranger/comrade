<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for Nostr relay connections -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Local network access for Saathi mDNS peer discovery -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- "Hey Comrade" voice assistant: microphone + always-listening service -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- CallService: keeps an in-progress call's process alive while the app
         is backgrounded. Required alongside the matching foregroundServiceType
         on Android 14+ (see CallService/the <service> entry below); video
         calls additionally use the camera type. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />

    <!-- Voice/video calls (WebRTC): camera capture for video calls and in-call
         audio routing (earpiece/speaker/Bluetooth/wired headset — see
         CallManager's AudioRoute). RECORD_AUDIO above already covers the
         microphone. The camera is declared optional so the app still installs
         on camera-less devices — voice calls don't need it. Bluetooth headset
         routing uses only AudioManager APIs (device enumeration + legacy SCO),
         never android.bluetooth.*, so no BLUETOOTH_CONNECT permission is needed. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- Ringing/vibrating for an incoming call (Ringer.kt). Normal permission —
         no runtime prompt. -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Required for Notifier.notifyIncomingCall's CallStyle notification: on
         the callee side there is no foreground service yet while merely
         ringing (CallService only starts once the call is accepted/placed),
         so the fullScreenIntent it already sets is the only one of
         CallStyle's three allowed conditions available at ring time. Without
         this declared, the platform silently treats fullScreenIntent as
         absent too, and NotificationManagerCompat.notify throws
         IllegalArgumentException instead of posting. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- allowBackup=false: the encrypted vault must not leave the device via
         adb/cloud backup — an exported copy is an offline brute-force target. -->
    <application
        android:name=".ComradeApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Comrade">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Handles the Decline/Hang Up actions on the call notifications'
             CallStyle (Notifier.notifyIncomingCall, CallService). Not
             exported: only this app's own PendingIntents ever invoke it. -->
        <receiver
            android:name=".CallActionReceiver"
            android:exported="false" />

        <!-- Keeps the process alive with an ongoing-call notification for the
             duration of a call's live media — see CallService's doc comment.
             foregroundServiceType declares the maximum this service may use;
             each startForeground() call passes the subset it actually needs
             (microphone alone for voice, +camera for video). -->
        <service
            android:name=".call.CallService"
            android:exported="false"
            android:foregroundServiceType="camera|microphone" />

        <!-- Always-listening "Hey Comrade" wake-word foreground service -->
        <service
            android:name=".voice.WakeWordService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Assist app: the assist gesture (long-press power) opens Comrade -->
        <service
            android:name=".voice.ComradeInteractionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/interaction_service" />
        </service>

        <service
            android:name=".voice.ComradeInteractionSessionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION" />

        <!-- Offline recognition service backing the assist registration -->
        <service
            android:name=".voice.ComradeRecognitionService"
            android:exported="true"
            android:permission="android.permission.RECORD_AUDIO">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>
            <meta-data
                android:name="android.speech"
                android:resource="@xml/recognition_service" />
        </service>

        <!-- Hands a decrypted media attachment to another app (e.g. opening a
             video/document externally) as a content:// URI instead of a raw
             file:// path, which Android has blocked cross-app since N. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
